# Orion Quant Platform — .gitignore

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment
.env
*.env

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

